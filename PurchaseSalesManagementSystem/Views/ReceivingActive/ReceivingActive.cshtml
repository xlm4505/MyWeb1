@{
    Layout = null;
    var envValue = Context.Session.GetString("Environment");
}


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Receiving Active - Fujikin</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="p-4">
    <!-- ナビバー -->
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Home/Menu">
                ← Back to Menu

                @if (envValue == "Product")
                {
                    <span style="color:red; font-weight:bold; margin-left:10px;">
                        .....Product Environment.....
                    </span>
                }
                else if (envValue == "Staging")
                {
                    <span style="color:yellow; font-weight:bold; margin-left:10px;">
                        .....Staging Environment.....
                    </span>
                }
                else if (envValue == "noshow")
                {

                }
            </a>
            <span class="text-white">Receiving Active</span>
        </div>
    </nav>

    <!-- アップロードフォーム -->
    <div class="card p-3">
        <input type="file" id="fileInput" class="form-control mb-3" accept=".xlsx,.xls,.xlsm" multiple>

        <!-- 選択ファイル一覧（枠付き） -->
        <div id="fileList" class="border rounded p-2 mb-3" style="min-height:60px;">
            <strong>File Selected:</strong>
            <ul id="fileListItems" class="mb-0"></ul>
        </div>

        <!-- アップロードボタン -->
        <button id="btnUpload" class="btn btn-primary">Update</button>
    </div>

    <!-- メッセージ表示 -->
    <div id="messageArea" class="mt-3 text-primary fw-bold"></div>

    <script src="~/js/ReceivingActive.js"></script>
</body>
</html>
