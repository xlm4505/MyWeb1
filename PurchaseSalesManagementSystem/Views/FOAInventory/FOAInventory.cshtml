@{
    Layout = null;
    var envValue = Context.Session.GetString("Environment");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>FOA Inventory - Fujikin</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        .tab-content {
            max-height: 500px;
            overflow-y: auto;
            overflow-x: auto;
            display: block;
        }

        #gridMain thead th {
            position: sticky;
            top: 0;
            background: white;
            z-index: 10;
            white-space: nowrap;
        }

        table th, table td {
            white-space: nowrap;
        }
    </style>
</head>
<body class="p-4">

    <!-- ナビバー -->
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Home/Menu">
                ← Back to Menu

                @if (envValue == "Product")
                {
                    <span style="color:red; font-weight:bold; margin-left:10px;">
                        .....Product Environment.....
                    </span>
                }
                else if (envValue == "Staging")
                {
                    <span style="color:yellow; font-weight:bold; margin-left:10px;">
                        .....Staging Environment.....
                    </span>
                }
                else if (envValue == "noshow")
                {

                }
            </a>
            <span class="text-white">FOA Inventory Query</span>
        </div>
    </nav>

    <!-- 検索フォーム -->
    <div class="d-flex align-items-center gap-3 mb-3">
        <label for="search">ItemCode:</label>
        <input type="text" id="search" class="form-control w-auto">

        <label for="warehouse">WareHouse:</label>
        <select id="warehouse" class="form-select w-auto">
            <option value="">All</option>
        </select>

        <!-- Minus inventory チェック -->
        <div class="form-check">
            <input class="form-check-input" type="checkbox" id="minusInventory">
            <label class="form-check-label" for="minusInventory">
                Minus inventory
            </label>
        </div>

        <button class="btn btn-primary" onclick="searchItems()">Search</button>
    </div>

    <!-- テーブル -->
    <div class="tab-content mt-3">
        <div class="tab-pane fade show active" id="main">
            <table class="table table-bordered table-sm" id="gridMain"><thead><tr></tr></thead><tbody></tbody></table>
        </div>
    </div>

    <!-- 操作ボタン -->
    <div class="mt-4">
        <button id="btnRefresh" class="btn btn-success">Refresh</button>
        <button id="btnExport" class="btn btn-success">Export to Excel</button>
    </div>

    <script src="~/js/FOAInventory.js"></script>
</body>
</html>
