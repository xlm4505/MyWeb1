@{
    Layout = null;
}


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Sales History Detail Report - Fujikin</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="~/js/SalesHistoryDetail.js"></script>
</head>
<body class="p-4 bg-light">

    <!-- ナビバー -->
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Home/Menu">← Back to Menu</a>
            <span class="text-white">Sales History Detail Report</span>
        </div>
    </nav>

    <!-- 左端揃え＆幅制限 -->
    <div style="max-width:700px; margin-left:0; margin-right:auto;">
        <div class="card p-4">
            <form id="searchForm">

                <!-- Customer -->
                <div class="mb-3 row">
                    <label class="col-sm-3 col-form-label">Customer</label>
                    <div class="col">
                        <input type="text" id="customer" list="customerList" class="form-control" placeholder="*ALL" autocomplete="off">
                        <datalist id="customerList"></datalist>
                    </div>
                </div>

                <!-- Item Code -->
                <div class="mb-3 row">
                    <label class="col-sm-3 col-form-label">Item Code</label>
                    <div class="col">
                        <input type="text" id="itemCode" list="itemCodeList" class="form-control" placeholder="*ALL" autocomplete="off">
                        <datalist id="itemCodeList"></datalist>
                    </div>
                </div>

                <!-- Item Description -->
                <div class="mb-3 row">
                    <label class="col-sm-3 col-form-label">Item Description</label>
                    <div class="col">
                        <input type="text" id="itemDesc" list="itemDescList" class="form-control" placeholder="*ALL" autocomplete="off">
                        <datalist id="itemDescList"></datalist>
                    </div>
                </div>

                <!-- Operation Date -->
                <div class="mb-3 row">
                    <label class="col-sm-3 col-form-label">Operation Date</label>
                    <div class="col-sm-4">
                        <input type="date" id="dateFrom" class="form-control">
                    </div>
                    <div class="col-sm-1 text-center">～</div>
                    <div class="col-sm-4">
                        <input type="date" id="dateTo" class="form-control">
                    </div>
                </div>

                <!-- RUN Button -->
                <div class="mb-3 row">
                    <div class="col-sm-12 text-end">
                        <button type="button" class="btn btn-primary" onclick="doRun()">RUN</button>
                    </div>
                </div>
            </form>
        </div>

        <!-- Console log 表示 -->
        <div id="checklist" class="mt-4" style="display:none;">
            <ul id="logList" class="list-group"></ul>
        </div>
    </div>

</body>
</html>
