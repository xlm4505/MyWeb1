@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
	<title>Katsuo Issue Date Table View</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        .table-container {
            overflow-y: auto;
            overflow-x: auto;
            display: block;
        }

        #gridMain thead th {
            position: sticky;
            top: 0;
            background: white;
            z-index: 10;
            white-space: nowrap;
        }

        table th, table td {
            white-space: nowrap;
        }
    </style>
</head>
<body class="p-4 bg-light">

    <!-- ナビバー -->
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Home/Menu">← Back to Menu</a>
            <span class="text-white">Katsuo Issue Date</span>
        </div>
    </nav>

    <!-- コンテンツ -->
    <div style="max-width:700px; margin-left:0; margin-right:auto;">
        <h3 class="mb-3">Katsuo Issue Date Table</h3>

    <!-- 検索フォーム -->
        <form id="searchForm" class="d-flex mb-3">
			<input type="text" id="userName" class="form-control me-2" placeholder="Enter UserName">
            <button class="btn btn-primary" id="btnSearch">Search</button>
        </form>

        <!-- データ表示テーブル -->
        <div class="table-container" id="tableContainer">
			<table class="table table-bordered table-sm" id="gridMain">
				<thead><tr></tr></thead>
				<tbody></tbody>
			</table>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/KatsuoIssueDate.js"></script>
</body>
</html>
