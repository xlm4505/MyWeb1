﻿@{
Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Item Code Master - Fujikin</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        .table-wrapper {
            max-height: 500px;
            overflow: auto;
            background-color: #fff;
        }

        table th, table td {
            white-space: nowrap;
        }

        #gridMain thead th {
            text-align: center;
            vertical-align: middle;
        }

    </style>
</head>
<body class="p-4 bg-light">
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Home/Menu">← Back to Menu</a>
            <span class="text-white">Item Code Master</span>
        </div>
    </nav>

    <div style="max-width:900px; margin-left:0; margin-right:auto;">
        <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
            <label for="itemCode" class="mb-0">Item Code:</label>
            <input type="text" id="itemCode" class="form-control w-auto">
            <div class="form-check mb-0">
                <input class="form-check-input" type="checkbox" id="excludeInactiveItems">
                <label class="form-check-label" for="excludeInactiveItems">Exclude inactive items</label>
            </div>
            <button class="btn btn-primary" id="btnSearch">Search</button>
        </div>
    </div>

    <div class="table-wrapper mt-3">
        <table class="table table-bordered table-sm mb-0" id="gridMain">
            <thead></thead>
            <tbody></tbody>
        </table>
    </div>
    <div style="max-width:900px; margin-left:0; margin-right:auto;">
        <div class="mt-4">
            <button class="btn btn-success" id="btnExport" disabled>Export to Excel</button>
        </div>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/ItemCodeMaster.js"></script>
</body>
</html>