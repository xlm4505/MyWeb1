@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>dbo_U_ForecastItem Maintenance</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        .table-container {
            max-height: 500px;
            overflow-y: auto;
            overflow-x: auto;
            display: block;
        }

        #gridMain thead th {
            position: sticky;
            top: 0;
            background: white;
            z-index: 10;
            white-space: nowrap;
        }

        table th, table td {
            white-space: nowrap;
        }
    </style>
</head>
<body class="p-4 bg-light">

    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Home/Menu">← Back to Menu</a>
            <span class="text-white">dbo_U_ForecastItem Maintenance</span>
        </div>
    </nav>

    <div style="max-width: 1000px; margin-left: 0; margin-right: auto;">
        <h3 class="mb-3">dbo_U_ForecastItem Table Maintenance</h3>

        <form id="searchForm" class="d-flex mb-3">
            <input type="text" id="searchCode" class="form-control me-2" placeholder="Enter ItemCode">
            <button type="submit" class="btn btn-primary">Search</button>
            <button type="button" id="addButton" class="btn btn-success ms-2">Add</button>
        </form>

        <div class="table-container">
            <table class="table table-bordered table-sm" id="gridMain">
                <thead>
                    <tr>
                        <th>ItemCode</th>
                        <th>ProcType</th>
                        <th>ARDivisionNo</th>
                        <th>CustomerNo</th>
                        <th>WarehouseCode</th>
                        <th>Quantity</th>
                        <th>ItemNo</th>
                        <th>Comment</th>
                        <th>Select</th>
                    </tr>
                </thead>
                <tbody id="dataBody"></tbody>
            </table>
        </div>

        <div id="actionArea" class="mt-3" style="display:none;">
            <button class="btn btn-success me-2" type="button" onclick="updateSelected()">Update</button>
            <button class="btn btn-danger" type="button" onclick="deleteSelected()">Delete</button>
            <button class="btn btn-success" type="button" onclick="downloadExcel()">Export to Excel</button>
        </div>
    </div>
    <div id="addModal" class="modal" tabindex="-1" style="display:none; background: rgba(0,0,0,.5);">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Forecast Item</h5>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="addItemCode" class="form-label">ItemCode *</label>
                            <input type="text" id="addItemCode" class="form-control" maxlength="30">
                        </div>
                        <div class="col-md-6">
                            <label for="addProcType" class="form-label">ProcType *</label>
                            <input type="text" id="addProcType" class="form-control" maxlength="1">
                        </div>
                        <div class="col-md-6">
                            <label for="addArDivisionNo" class="form-label">ARDivisionNo</label>
                            <input type="text" id="addArDivisionNo" class="form-control" maxlength="2">
                        </div>
                        <div class="col-md-6">
                            <label for="addCustomerNo" class="form-label">CustomerNo</label>
                            <input type="text" id="addCustomerNo" class="form-control" maxlength="20">
                        </div>
                        <div class="col-md-6">
                            <label for="addWarehouseCode" class="form-label">WarehouseCode</label>
                            <input type="text" id="addWarehouseCode" class="form-control" maxlength="3">
                        </div>
                        <div class="col-md-6">
                            <label for="addQuantity" class="form-label">Quantity *</label>
                            <input type="text" id="addQuantity" class="form-control modal-signed-number-7" inputmode="decimal" maxlength="8">
                        </div>
                        <div class="col-md-6">
                            <label for="addItemNo" class="form-label">ItemNo</label>
                            <input type="text" id="addItemNo" class="form-control modal-number-7" inputmode="numeric" maxlength="7">
                        </div>
                        <div class="col-md-6">
                            <label for="addComment" class="form-label">Comment</label>
                            <input type="text" id="addComment" class="form-control editable-halfwidth" data-maxlength="30" maxlength="30">
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" id="okAddButton" class="btn btn-primary">Ok</button>
                    <button type="button" id="closeAddButton" class="btn btn-secondary">Close</button>
                </div>
            </div>
        </div>
    </div>

    <script src="~/js/SafetyStockMaintenance.js"></script>
</body>
</html>